---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { CountryDetail } from '../../components/CountryDetail';
import { Footer } from '../../components/Footer';
import { WhatsAppButton } from '../../components/WhatsAppButton';
import { AIAssistant } from '../../components/AIAssistant';
---

<Layout
  title="Study in the United States | AtlasPath — Find Your Dream US University"
  description="Discover top research universities and Ivy League colleges in the US, compare tuition fees, STEM OPT work permits, living costs, and scholarships like Fulbright."
>
  <Navbar client:load />
  <CountryDetail countryId="usa" client:load />
  <Footer client:visible />
  <WhatsAppButton client:visible />
  <AIAssistant client:visible />
</Layout>
